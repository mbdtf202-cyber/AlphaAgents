# AlphaAgents agent-native marketplace baseline
ALPHAAGENTS_ENV=development
ALPHAAGENTS_APP_URL=http://localhost:13100
ALPHAAGENTS_API_URL=http://localhost:13100/api

# Domain storage
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/alphaagents
REDIS_URL=redis://127.0.0.1:6379
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9002
OBJECT_STORAGE_BUCKET=alphaagents-evidence
OBJECT_STORAGE_ACCESS_KEY_ID=minio
OBJECT_STORAGE_SECRET_ACCESS_KEY=minio123
OBJECT_STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:9002/alphaagents-evidence

# Agent runtime
ALPHAAGENTS_RUNTIME_MODE=local
ALPHAAGENTS_RUNTIME_CALLBACK_URL=http://localhost:13100/api/runtime/events
ALPHAAGENTS_EVIDENCE_RETENTION_DAYS=365
ALPHAAGENTS_DEFAULT_AGENT_PERMISSION_POLICY=human_approval_for_high_risk

# CLI control plane
ALPHAAGENTS_CLI_PROFILE=local
ALPHAAGENTS_CLI_OUTPUT_FORMAT=json
ALPHAAGENTS_CLI_AUDIT_EVENTS=true

# Escrow and transaction state
ALPHAAGENTS_ESCROW_PROVIDER=mock
ALPHAAGENTS_ESCROW_CURRENCY=CNY
# Local development placeholder only. Canonical business finance rules live in contracts/alphaagents.contract.json.
ALPHAAGENTS_PLATFORM_FEE_BPS=__SET_PER_ORDER_OR_DEFAULT_POLICY__

# Auth and notifications
ALPHAAGENTS_AUTH_SECRET=replace-with-a-long-random-secret
POSTMARK_SERVER_TOKEN=replace-with-postmark-server-token
POSTMARK_FROM_EMAIL=noreply@example.com
POSTMARK_MESSAGE_STREAM=outbound

# Observability
SENTRY_DSN=https://public@example.ingest.sentry.io/1
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=agent-native-reset

# Non-production only
ALPHAAGENTS_ENABLE_TEST_MAILER=false
ALPHAAGENTS_DISABLE_RATE_LIMITS=false
ALPHAAGENTS_FORCE_INSECURE_COOKIES=false
