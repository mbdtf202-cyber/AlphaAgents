      "sourceChannels": ["ui", "cli", "api"],
      "scopeMode": "all",
      "payloadRequired": ["orderId", "subjectType", "subjectId", "agentVersion", "categoryIds", "ratingBreakdown", "deliveryOutcome"],
      "requiredScopes": ["buyer:ratings.write"],
      "successEvents": ["ReputationEventCreated", "ReputationPublished"],
      "failureCodes": ["ORDER_NOT_COMPLETED", "DUPLICATE_RATING", "ACTOR_FORBIDDEN"],
      "responseDto": "ReputationDto"
    }
  },
  "queries": {
    "reputation.show": {
      "actorRoles": ["buyer", "seller", "operator"],
      "sourceChannels": ["ui", "cli", "api"],
      "scopeMode": "all",
      "payloadRequired": ["subjectId"],
      "requiredScopes": ["reputation:read"],
      "responseDto": "ReputationSummaryDto"
    },
    "evidence.show": {
      "actorRoles": ["buyer", "seller", "operator", "agent_runtime"],
      "sourceChannels": ["ui", "cli", "api", "runtime"],
      "scopeMode": "all",
      "payloadRequired": ["evidenceId"],
      "requiredScopes": ["evidence:read"],
      "responseDto": "EvidenceDto"
    }
  },
  "financeRules": {
    "currency": "CNY",
    "rounding": "all money is integer minor units; release/refund split must sum to orderAmountMinor minus explicit penaltyAmountMinor",
    "fullRelease": {
      "condition": "acceptanceScore >= 85 and no critical breach",
      "releaseAmountMinor": "orderAmountMinor",
      "refundAmountMinor": 0
    },
    "partialRelease": {
      "condition": "70 <= acceptanceScore < 85 or dispute decision partial_release",
      "releaseAmountMinorFormula": "floor(orderAmountMinor * acceptedCriteriaWeightBps / 10000) - penaltyAmountMinor",
      "refundAmountMinorFormula": "orderAmountMinor - releaseAmountMinor",
      "acceptedCriteriaWeightSource": "frozen buyerAcceptanceMiniTerms criteria decisions"
    },
    "refund": {
      "condition": "acceptanceScore < 70 or critical breach",
      "releaseAmountMinor": 0,
      "refundAmountMinor": "orderAmountMinor"
    }
  },
