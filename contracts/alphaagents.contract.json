{
  "metadata": {
    "name": "alphaagents-agent-native-transaction-contract",
    "version": "0.1.0-sandbox",
    "sourceOfTruth": true,
    "commercialEvidenceBoundary": "sandbox_verified is not validated commercial evidence; validated requires real payment, LOI, procurement email, or customer-authorized delivery package"
  },
  "defaultFirstPurchase": {
    "packageTier": "trial",
    "priceAmountMinor": 198000,
    "currency": "CNY",
    "deliveryHours": 48,
    "eligibleBuyer": "US TikTok Shop beauty and personal-care cross-border content-growth team",
    "enterprisePocEntryCriteria": [
      "one Trial accepted with score >= 85",
      "named buyer owner, finance contact, and legal contact",
      "5-10 order backlog or weekly repeat need",
      "read-only data boundary accepted"
    ]
  },
  "evidenceStatuses": [
    "validated",
    "sandbox_verified",
    "in_conversation",
    "sample_only",
    "target_to_collect"
  ],
  "commandDefaults": {
    "requiresEnvelope": [
      "commandId",
      "actorId",
      "actorRole",
      "sourceChannel",
      "tenantId",
      "tokenScopes",
      "idempotencyKey",
      "correlationId",
      "expectedVersion"
    ],
    "idempotent": true,
    "requiresOptimisticLock": true,
    "preflightChecks": [
      "tenant",
      "tokenScope",
      "actorRole",
      "objectOwnership",
      "rateLimit",
      "idempotency"
    ]
  },
  "packages": {
    "trial": {
      "priceAmountMinor": 198000,
      "deliveryHours": 48,
      "competitors": 5,
      "evidenceRefs": 20,
      "topicIdeas": 15
    },
    "standard": {
      "priceAmountMinor": 680000,
      "deliveryHours": 72,
      "competitors": 10,
      "evidenceRefs": 60,
      "topicIdeas": 30
    },
    "pro": {
      "priceAmountMinor": 1800000,
      "deliveryHours": 120,
      "competitors": 20,
      "evidenceRefs": 100,
      "topicIdeas": 60
    }
  },
  "buyerAcceptanceMiniTerms": [
    {
      "id": "competitor_coverage",
      "weight": 20,
      "buyerText": "Covers the agreed number of competitors or explains any unavailable public source."
    },
    {
      "id": "evidence_traceability",
      "weight": 25,
      "buyerText": "Every key claim links to an EvidenceRef with URL or screenshot/hash backup."
    },
    {
      "id": "topic_actionability",
      "weight": 20,
      "buyerText": "Delivers the agreed number of topic ideas with hook, audience, angle, evidence, and priority."
    },
    {
      "id": "factual_accuracy",
      "weight": 15,
      "buyerText": "No material factual error in sampled product, price, claim, channel, or source statements."
    },
    {
      "id": "file_completeness",
      "weight": 10,
      "buyerText": "Required files open and contain the required sections."
    },
    {
      "id": "on_time_delivery",
      "weight": 10,
      "buyerText": "Delivery is submitted within the package SLA after payment/material confirmation."
    }
  ],
  "statuses": {
    "buyerLifecycleStage": ["anonymous_visitor", "trial_lead", "org_setup", "trial_paid", "accepted_trial", "repeat_buyer", "poc_program", "annual_order_credit_customer", "churn_risk"],
    "appInstallStatus": ["active", "exited"],
    "appUsageStatus": ["recorded"],
    "programQbrStatus": ["not_started", "in_progress", "ready_for_review"],
    "customProjectStatus": ["intake_submitted", "milestone_confirmed", "uat_submitted", "change_requested"],
    "customProjectUatStatus": ["not_started", "submitted"],
    "rfpStatus": ["draft", "published", "quoting", "selected", "ordered", "cancelled"],
    "proposalStatus": ["submitted", "selected", "declined", "expired", "withdrawn"],
    "orderStatus": ["created", "funded", "in_progress", "delivery_submitted", "ready_for_acceptance", "revision_requested", "disputed", "resolved", "accepted", "released", "partially_released", "refunded", "closed"],
    "ledgerStatus": ["not_funded", "escrowed", "locked", "released", "partially_released", "refunded"],
    "acceptanceStatus": ["not_ready", "qa_pending", "ready", "accepted", "revision_requested", "disputed", "resolved"],
    "grantStatus": ["requested", "approved", "revoked", "expired", "denied"],
    "runStatus": ["queued", "running", "succeeded", "failed", "cancelled"],
    "deliveryStatus": ["draft", "submitted", "qa_passed", "qa_rejected", "superseded"],
    "reviewStatus": ["accepted", "revision_requested", "disputed"],
    "eventStatus": ["pending", "published", "hidden_by_policy"]
  },
  "errorCodes": [
    "ACTOR_FORBIDDEN",
    "TENANT_FORBIDDEN",
    "TOKEN_SCOPE_FORBIDDEN",
    "VERSION_CONFLICT",
    "IDEMPOTENCY_CONFLICT",
    "VALIDATION_FAILED",
    "STATE_CONFLICT",
    "RFP_INCOMPLETE",
    "RFP_NOT_OPEN",
    "SELLER_NOT_APPROVED",
    "PROPOSAL_EXPIRED",
    "PAYMENT_NOT_CONFIRMED",
    "ESCROW_NOT_FUNDED",
    "PERMISSION_DENIED",
    "DELIVERY_INCOMPLETE",
    "QA_CHECK_FAILED",
    "CRITERIA_NOT_CONFIRMED",
    "REVISION_LIMIT_REACHED",
    "SCOPE_EXPANSION_REQUIRED",
    "DISPUTE_REASON_REQUIRED",
    "DECISION_INCOMPLETE",
    "ORDER_NOT_COMPLETED",
    "DUPLICATE_RATING",
    "EVIDENCE_NOT_VISIBLE",
    "RATE_LIMITED"
  ],
  "scopes": [
    "buyer:rfps.write",
    "buyer:orders.write",
    "buyer:acceptance.write",
    "buyer:disputes.write",
    "buyer:ratings.write",
    "seller:proposals.write",
    "seller:runs.write",
    "seller:deliveries.write",
    "runtime:runs.write",
    "runtime:deliveries.write",
    "operator:qa.write",
    "operator:disputes.write",
    "operator:acceptance.write",
    "operator:permissions.write",
    "operator:runs.write",
    "finance:ledger.write",
    "evidence:read",
    "evidence:export",
    "evidence:delete",
    "reputation:read"
  ],
  "commands": {
    "buyer-org.setup": {
      "mutates": true,
      "actorRoles": ["buyer"],
      "sourceChannels": ["ui", "cli", "api"],
      "scopeMode": "all",
      "payloadRequired": ["buyerOrgId", "requesterUserId", "acceptanceOwnerUserId", "financeContactUserId", "authorizedPayerId", "signerIds", "invoiceReadiness", "scopeAcknowledgement"],
      "requiredScopes": ["buyer:orders.write"],
      "successEvents": ["BuyerOrgSetupUpdated"],
      "failureCodes": ["ACTOR_FORBIDDEN", "TENANT_FORBIDDEN", "VALIDATION_FAILED"],
      "responseDto": "BuyerOrgProfileDto"
    },
    "custom-project.request": {
      "mutates": true,
      "actorRoles": ["buyer"],
      "sourceChannels": ["ui", "cli", "api"],
      "scopeMode": "all",
      "payloadRequired": ["projectId", "buyerOrgId", "projectTitle", "categoryId", "targetOutcome", "requestedBy"],
      "requiredScopes": ["buyer:orders.write"],
      "successEvents": ["CustomProjectRequested"],
      "failureCodes": ["ACTOR_FORBIDDEN", "TENANT_FORBIDDEN", "VALIDATION_FAILED", "STATE_CONFLICT"],
      "responseDto": "CustomProjectDto"
    },
