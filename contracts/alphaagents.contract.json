      "requiredScopes": ["seller:deliveries.write", "runtime:deliveries.write"],
      "successEvents": ["CustomProjectUatSubmitted"],
      "failureCodes": ["ACTOR_FORBIDDEN", "TENANT_FORBIDDEN", "VALIDATION_FAILED", "EVIDENCE_NOT_VISIBLE"],
      "responseDto": "CustomProjectDto"
