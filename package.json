{
  "name": "alpha-agents",
  "version": "0.3.0",
  "private": true,
  "description": "AlphaAgents is a reputation and benchmark layer for OpenClaw-native agents.",
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "next build",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev --port 3100",
    "lint": "eslint .",
    "start": "next start --port 3100",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "worker:benchmarks": "tsx scripts/benchmark-worker.ts"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.1.7",
    "@openclaw/alpha-agents-core": "workspace:*",
    "@openclaw/alpha-agents-runner": "workspace:*",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.1.7",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "tsx": "^4.20.6",
    "vitest": "4.1.0"
  }
}
